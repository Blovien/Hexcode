hexstaff.basic.crude.name=Crude Hex Staff
hexstaff.basic.crude.description=<color is="#ffcc00"><b>+2</b></color> <color is="#aaaaaa">Volatility</color> - <color is="#8888ff"><b>1</b></color> <color is="#aaaaaa">Charge</color> - <color is="#cc88ff"><b>Ring</b></color> <color is="#aaaaaa">Style</color>\n\n<b>To draw spells</b>\nPress and Hold <b>Secondary</b> to enter <b>Drawing Mode</b>\nUse <b>Primary</b> to draw shapes in Drawing Mode\nRelease <b>Secondary</b> to submit Drawing\n\n<b>To cast spells</b>\nPress and Hold <b>Secondary</b> to view Drawn or Crafted Hexes\nHover over Hex to Select\nRelease <b>Secondary</b> to finalize Selection\n<b>Primary</b> to execute Hex
