$C = "../../Common.ui";

$C.@PageOverlay {
  LayoutMode: Middle;

  $C.@DecoratedContainer {
    Anchor: (Width: 420);

    #Title {
      $C.@Title {
        @Text = "Import / Export Hex";
      }
    }

    #Content {
      Padding: (Vertical: 16, Horizontal: 24);
      LayoutMode: Top;

      MultilineTextField #DataField {
        Anchor: (Height: 120);
        Style: InputFieldStyle(FontSize: 10, TextColor: #e0e0e0);
        Background: $C.@InputBoxBackground;
        PlaceholderText: "paste hex data here...";
      }

      Group #ButtonRow {
        LayoutMode: Left;
        Anchor: (Top: 12, Height: 36);

        $C.@TextButton #ExportButton {
          @Anchor = (Right: 8);
          Text: "Export Active Hex";
          FlexWeight: 1;
        }

        $C.@TextButton #ImportButton {
          Text: "Import to Book";
          FlexWeight: 1;
        }
      }

      Label #StatusLabel {
        Style: (FontSize: 14, TextColor: #a0a0a0);
        Text: "";
        Anchor: (Top: 12, Height: 40);
      }
    }
  }
}
